      "version": ""
    }
  ],
  "annotations": { "list": [] },
  "description": "eBPF-based process monitoring: CPU, memory, cgroups, I/O, network, files",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "links": [],
  "templating": {
    "list": [
      {
        "current": {},
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "definition": "SELECT DISTINCT hostname FROM default.process_metrics WHERE timestamp >= now() - INTERVAL 1 DAY ORDER BY hostname",
        "hide": 0,
        "includeAll": true,
        "label": "Server",
        "multi": true,
        "name": "hostname",
        "options": [],
        "query": "SELECT DISTINCT hostname FROM default.process_metrics WHERE timestamp >= now() - INTERVAL 1 DAY ORDER BY hostname",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": {},
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "definition": "SELECT DISTINCT rule FROM default.process_metrics WHERE timestamp >= now() - INTERVAL 1 DAY AND hostname IN (${hostname:sqlstring}) ORDER BY rule",
        "hide": 0,
        "includeAll": true,
        "label": "Rule",
        "multi": true,
        "name": "rule",
        "options": [],
        "query": "SELECT DISTINCT rule FROM default.process_metrics WHERE timestamp >= now() - INTERVAL 1 DAY AND hostname IN (${hostname:sqlstring}) ORDER BY rule",
        "refresh": 2,
        "regex": "",
        "skipUrlSync": false,
        "sort": 1,
        "type": "query"
      },
      {
        "current": { "selected": false, "text": "", "value": "" },
        "hide": 0,
        "label": "Process search",
        "name": "process_search",
        "options": [],
        "query": "",
        "skipUrlSync": false,
        "type": "textbox"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 100,
      "title": "Overview",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 500 }, { "color": "red", "value": 2000 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 1 },
      "id": 1,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 1,
        "queryType": "sql",
        "rawSql": "SELECT count(DISTINCT pid) AS processes FROM default.process_metrics WHERE event_type='snapshot' AND timestamp >= now() - INTERVAL 2 MINUTE AND hostname IN (${hostname:sqlstring}) AND rule IN (${rule:sqlstring})",
        "refId": "A"
      }],
      "title": "Active Processes",
      "type": "stat"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "unit": "decbytes",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 1073741824 }, { "color": "red", "value": 8589934592 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 1 },
      "id": 2,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 1,
        "queryType": "sql",
        "rawSql": "SELECT sum(rss_bytes) AS total_rss FROM default.process_metrics WHERE event_type='snapshot' AND timestamp >= now() - INTERVAL 2 MINUTE AND hostname IN (${hostname:sqlstring}) AND rule IN (${rule:sqlstring}) AND timestamp >= (SELECT max(timestamp) - INTERVAL 1 SECOND FROM default.process_metrics WHERE event_type='snapshot' AND hostname IN (${hostname:sqlstring}))",
        "refId": "A"
      }],
      "title": "Total RSS",
      "type": "stat"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "decimals": 2,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 2 }, { "color": "red", "value": 8 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 1 },
      "id": 3,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 1,
        "queryType": "sql",
        "rawSql": "SELECT sum(cpu_usage_ratio) AS total_cpu FROM default.process_metrics WHERE event_type='snapshot' AND timestamp >= now() - INTERVAL 2 MINUTE AND hostname IN (${hostname:sqlstring}) AND rule IN (${rule:sqlstring}) AND timestamp >= (SELECT max(timestamp) - INTERVAL 1 SECOND FROM default.process_metrics WHERE event_type='snapshot' AND hostname IN (${hostname:sqlstring}))",
        "refId": "A"
      }],
      "title": "Total CPU (cores)",
      "type": "stat"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 20 }, { "color": "red", "value": 100 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 1 },
      "id": 4,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 1,
        "queryType": "sql",
        "rawSql": "SELECT count(DISTINCT cgroup) AS cgroups FROM default.process_metrics WHERE event_type='snapshot' AND timestamp >= now() - INTERVAL 2 MINUTE AND hostname IN (${hostname:sqlstring}) AND cgroup_memory_current > 0",
        "refId": "A"
      }],
      "title": "Active Cgroups",
      "type": "stat"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "orange", "value": 10 }, { "color": "red", "value": 50 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 1 },
      "id": 5,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 1,
        "queryType": "sql",
        "rawSql": "SELECT count() AS events FROM default.process_metrics WHERE event_type IN ('fork','exec','exit','oom_kill') AND $__timeFilter(timestamp) AND hostname IN (${hostname:sqlstring})",
        "refId": "A"
      }],
      "title": "Events (period)",
      "type": "stat"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "red", "value": 1 }] }
        }
      },
      "gridPos": { "h": 4, "w": 4, "x": 20, "y": 1 },
      "id": 6,
      "options": { "colorMode": "background", "graphMode": "none", "reduceOptions": { "calcs": ["lastNotNull"], "fields": "", "values": false }, "textMode": "auto" },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 1,
        "queryType": "sql",
        "rawSql": "SELECT count() AS oom_kills FROM default.process_metrics WHERE event_type='oom_kill' AND $__timeFilter(timestamp) AND hostname IN (${hostname:sqlstring})",
        "refId": "A"
      }],
      "title": "OOM Kills",
      "type": "stat"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 5 },
      "id": 200,
      "title": "CPU & Memory (Top-5 Processes)",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 30, "lineWidth": 1, "pointSize": 3, "spanNulls": true, "stacking": { "mode": "normal" } },
          "decimals": 2,
          "unit": "short"
        },
        "overrides": [{
          "matcher": { "id": "byName", "options": "other" },
          "properties": [{ "id": "color", "value": { "fixedColor": "#cccccc", "mode": "fixed" } }]
        }]
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
      "id": 10,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "sortBy": "Max", "sortDesc": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 0,
        "queryType": "sql",
        "rawSql": "WITH top5 AS (\n  SELECT comm\n  FROM default.process_metrics\n  WHERE event_type='snapshot'\n    AND $__timeFilter(timestamp)\n    AND hostname IN (${hostname:sqlstring})\n    AND rule IN (${rule:sqlstring})\n  GROUP BY comm\n  ORDER BY avg(cpu_usage_ratio) DESC\n  LIMIT 5\n)\nSELECT\n  toStartOfInterval(timestamp, INTERVAL 3 SECOND) AS time,\n  if(comm IN (SELECT comm FROM top5), comm, 'other') AS process,\n  sum(cpu_usage_ratio) AS cpu_cores\nFROM default.process_metrics\nWHERE event_type='snapshot'\n  AND $__timeFilter(timestamp)\n  AND hostname IN (${hostname:sqlstring})\n  AND rule IN (${rule:sqlstring})\nGROUP BY time, process\nORDER BY time",
        "refId": "A"
      }],
      "title": "CPU Usage by Process (top-5 + other)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 30, "lineWidth": 1, "pointSize": 3, "spanNulls": true, "stacking": { "mode": "normal" } },
          "unit": "decbytes"
        },
        "overrides": [{
          "matcher": { "id": "byName", "options": "other" },
          "properties": [{ "id": "color", "value": { "fixedColor": "#cccccc", "mode": "fixed" } }]
        }]
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
      "id": 11,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom", "sortBy": "Max", "sortDesc": true }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 0,
        "queryType": "sql",
        "rawSql": "WITH top5 AS (\n  SELECT comm\n  FROM default.process_metrics\n  WHERE event_type='snapshot'\n    AND $__timeFilter(timestamp)\n    AND hostname IN (${hostname:sqlstring})\n    AND rule IN (${rule:sqlstring})\n  GROUP BY comm\n  ORDER BY avg(rss_bytes) DESC\n  LIMIT 5\n)\nSELECT\n  toStartOfInterval(timestamp, INTERVAL 3 SECOND) AS time,\n  if(comm IN (SELECT comm FROM top5), comm, 'other') AS process,\n  sum(rss_bytes) AS rss\nFROM default.process_metrics\nWHERE event_type='snapshot'\n  AND $__timeFilter(timestamp)\n  AND hostname IN (${hostname:sqlstring})\n  AND rule IN (${rule:sqlstring})\nGROUP BY time, process\nORDER BY time",
        "refId": "A"
      }],
      "title": "RSS Memory by Process (top-5 + other)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "custom": { "align": "auto", "filterable": true },
          "thresholds": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "cpu_cores" }, "properties": [{ "id": "unit", "value": "short" }, { "id": "decimals", "value": 3 }, { "id": "custom.cellOptions", "value": { "type": "color-background" } }, { "id": "thresholds", "value": { "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.5 }, { "color": "red", "value": 2 }] } }] },
          { "matcher": { "id": "byName", "options": "rss" }, "properties": [{ "id": "unit", "value": "decbytes" }] },
          { "matcher": { "id": "byName", "options": "pids" }, "properties": [{ "id": "custom.width", "value": 60 }] }
        ]
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 14 },
      "id": 12,
      "options": { "showHeader": true, "sortBy": [{ "desc": true, "displayName": "cpu_cores" }], "footer": { "enablePagination": true } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 1,
        "queryType": "sql",
        "rawSql": "SELECT\n  comm,\n  any(exec) AS exec_path,\n  any(args) AS cmdline,\n  any(uid) AS uid,\n  any(rule) AS match_rule,\n  length(groupUniqArray(pid)) AS pids,\n  sum(cpu_usage_ratio) AS cpu_cores,\n  sum(rss_bytes) AS rss,\n  sum(io_read_bytes) AS io_read,\n  sum(io_write_bytes) AS io_write\nFROM default.process_metrics\nWHERE event_type='snapshot'\n  AND hostname IN (${hostname:sqlstring})\n  AND rule IN (${rule:sqlstring})\n  AND timestamp >= (SELECT max(timestamp) - INTERVAL 1 SECOND FROM default.process_metrics WHERE event_type='snapshot' AND hostname IN (${hostname:sqlstring}))\nGROUP BY comm\nORDER BY cpu_cores DESC\nLIMIT 30",
        "refId": "A"
      }],
      "title": "Process Details (latest snapshot)",
      "type": "table"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 25 },
      "id": 300,
      "title": "Cgroup Memory",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 30, "lineWidth": 1, "pointSize": 3, "spanNulls": true, "stacking": { "mode": "none" } },
          "unit": "decbytes"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 15 },
      "id": 20,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 0,
        "queryType": "sql",
        "rawSql": "SELECT\n  toStartOfInterval(timestamp, INTERVAL 10 SECOND) AS time,\n  cgroup,\n  max(cgroup_memory_current) AS mem_current\nFROM default.process_metrics\nWHERE event_type='snapshot'\n  AND $__timeFilter(timestamp)\n  AND hostname IN (${hostname:sqlstring})\n  AND cgroup_memory_current > 0\nGROUP BY time, cgroup\nHAVING max(cgroup_memory_current) > 10485760\nORDER BY time",
        "refId": "A"
      }],
      "title": "Cgroup Memory Usage (current)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 30, "lineWidth": 2, "pointSize": 3, "spanNulls": true, "stacking": { "mode": "none" }, "thresholdsStyle": { "mode": "line" } },
          "unit": "percentunit",
          "max": 1,
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] }
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 15 },
      "id": 21,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 0,
        "queryType": "sql",
        "rawSql": "SELECT\n  toStartOfInterval(timestamp, INTERVAL 10 SECOND) AS time,\n  cgroup,\n  max(cgroup_memory_current) / max(cgroup_memory_max) AS usage_pct\nFROM default.process_metrics\nWHERE event_type='snapshot'\n  AND $__timeFilter(timestamp)\n  AND hostname IN (${hostname:sqlstring})\n  AND cgroup_memory_max > 0\n  AND cgroup_memory_current > 0\nGROUP BY time, cgroup\nORDER BY time",
        "refId": "A"
      }],
      "title": "Cgroup Memory % (current / max)",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "thresholds" },
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": null }, { "color": "yellow", "value": 0.7 }, { "color": "red", "value": 0.9 }] },
          "custom": { "align": "auto", "displayMode": "auto" }
        },
        "overrides": [
          { "matcher": { "id": "byName", "options": "mem_current" }, "properties": [{ "id": "unit", "value": "decbytes" }] },
          { "matcher": { "id": "byName", "options": "mem_max" }, "properties": [{ "id": "unit", "value": "decbytes" }] },
          { "matcher": { "id": "byName", "options": "swap" }, "properties": [{ "id": "unit", "value": "decbytes" }] },
          { "matcher": { "id": "byName", "options": "usage_pct" }, "properties": [{ "id": "unit", "value": "percentunit" }, { "id": "custom.displayMode", "value": "gradient-gauge" }, { "id": "max", "value": 1 }] }
        ]
      },
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 23 },
      "id": 22,
      "options": { "showHeader": true, "sortBy": [{ "desc": true, "displayName": "usage_pct" }] },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 1,
        "queryType": "sql",
        "rawSql": "SELECT\n  cgroup,\n  any(rule) AS rule,\n  max(cgroup_memory_current) AS mem_current,\n  max(cgroup_memory_max) AS mem_max,\n  if(max(cgroup_memory_max) > 0, max(cgroup_memory_current) / max(cgroup_memory_max), 0) AS usage_pct,\n  max(cgroup_swap_current) AS swap,\n  max(cgroup_cpu_weight) AS cpu_weight,\n  max(cgroup_pids_current) AS pids\nFROM default.process_metrics\nWHERE event_type='snapshot'\n  AND timestamp >= now() - INTERVAL 2 MINUTE\n  AND hostname IN (${hostname:sqlstring})\n  AND cgroup_memory_current > 0\nGROUP BY cgroup\nORDER BY usage_pct DESC",
        "refId": "A"
      }],
      "title": "Cgroup Details (latest)",
      "type": "table"
    },

    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 31 },
      "id": 400,
      "title": "Per-Process Metrics",
      "type": "row"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "drawStyle": "line", "fillOpacity": 10, "lineWidth": 1, "pointSize": 3, "spanNulls": true, "stacking": { "mode": "none" } },
          "decimals": 3,
          "unit": "short"
        }
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "id": 30,
      "options": { "legend": { "calcs": ["mean", "max"], "displayMode": "table", "placement": "bottom" }, "tooltip": { "mode": "multi", "sort": "desc" } },
      "targets": [{
        "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
        "format": 0,
        "queryType": "sql",
        "rawSql": "SELECT\n  toStartOfInterval(timestamp, INTERVAL 10 SECOND) AS time,\n  concat(comm, ' [', toString(pid), ']') AS process,\n  max(cpu_usage_ratio) AS cpu\nFROM default.process_metrics\nWHERE event_type='snapshot'\n  AND $__timeFilter(timestamp)\n  AND hostname IN (${hostname:sqlstring})\n  AND rule IN (${rule:sqlstring})\n  AND cpu_usage_ratio > 0.001\n  AND (length('${process_search}') = 0 OR (exec ILIKE '%${process_search}%' OR comm ILIKE '%${process_search}%' OR args ILIKE '%${process_search}%'))\nGROUP BY time, process\nORDER BY time",
        "refId": "A"
      }],
      "title": "CPU by Process",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "grafana-clickhouse-datasource", "uid": "${DS_CLICKHOUSE}" },
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
