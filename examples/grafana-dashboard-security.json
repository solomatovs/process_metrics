          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  sec_remote_addr AS remote_ip,\n  sec_remote_port AS remote_port,\n  count() AS retransmits,\n  uniq(pid) AS processes,\n  groupUniqArray(5)(comm) AS commands,\n  any(sec_tcp_state) AS tcp_state\nFROM default.process_metrics\nWHERE event_type = 'tcp_retrans'\n  AND sec_remote_addr != ''\n  AND timestamp >= $__fromTime AND timestamp <= $__toTime\n  AND hostname IN (${hostname:sqlstring})\nGROUP BY sec_remote_addr, sec_remote_port\nORDER BY retransmits DESC\nLIMIT 30",
