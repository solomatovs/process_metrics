      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${DS_CLICKHOUSE}"
          },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  sec_remote_addr AS remote_ip,\n  count() AS total_events,\n  uniq(sec_local_port) AS unique_ports,\n  groupUniqArrayIf(10)(toString(sec_local_port), sec_local_port > 0) AS scanned_ports,\n  min(timestamp) AS first_seen,\n  max(timestamp) AS last_seen\nFROM default.process_metrics\nWHERE event_type IN ('syn_recv', 'rst_sent', 'rst_recv')\n  AND sec_remote_addr != ''\n  AND timestamp >= $__fromTime AND timestamp <= $__toTime\n  AND hostname IN (${hostname:sqlstring})\nGROUP BY sec_remote_addr\nORDER BY unique_ports DESC, total_events DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Potential Scanners (by unique ports touched)",
      "type": "table"
    },
