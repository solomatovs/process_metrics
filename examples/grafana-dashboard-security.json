      "options": {
        "showHeader": true,
        "sortBy": [
          {
            "desc": true,
            "displayName": "anomaly_score"
          }
        ]
      },
      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${DS_CLICKHOUSE}"
          },
          "format": 1,
          "queryType": "sql",
          "rawSql": "WITH per_ip AS (\n  SELECT\n    sec_remote_addr AS ip,\n    countIf(event_type = 'syn_recv') AS syns,\n    countIf(event_type IN ('rst_sent', 'rst_recv')) AS rsts,\n    countIf(event_type = 'tcp_retrans') AS retrans,\n    uniqIf(sec_local_port, event_type = 'syn_recv') AS unique_ports_scanned,\n    min(timestamp) AS first_seen,\n    max(timestamp) AS last_seen\n  FROM default.process_metrics\n  WHERE event_type IN ('syn_recv', 'rst_sent', 'rst_recv', 'tcp_retrans')\n    AND sec_remote_addr != ''\n    AND timestamp >= $__fromTime AND timestamp <= $__toTime\n    AND hostname IN (${hostname:sqlstring})\n  GROUP BY sec_remote_addr\n)\nSELECT\n  ip,\n  syns,\n  rsts,\n  retrans,\n  unique_ports_scanned,\n  first_seen,\n  last_seen,\n  round(\n    syns * 1.0 +\n    rsts * 0.5 +\n    retrans * 0.3 +\n    unique_ports_scanned * 5.0\n  , 1) AS anomaly_score,\n  multiIf(\n    unique_ports_scanned >= 10, 'PORT SCAN',\n    syns >= 100, 'SYN FLOOD',\n    rsts >= 50, 'RST FLOOD',\n    retrans >= 200, 'HIGH RETRANSMIT',\n    'NORMAL'\n  ) AS verdict\nFROM per_ip\nWHERE syns + rsts + retrans > 0\nORDER BY anomaly_score DESC\nLIMIT 50",
          "refId": "A"
        }
      ],
      "title": "Suspicious IPs (Anomaly Score)",
      "type": "table"
