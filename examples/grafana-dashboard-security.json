          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  sec_local_port AS port,\n  countIf(event_type = 'syn_recv') AS syn_count,\n  countIf(event_type = 'rst_sent') AS rst_sent,\n  countIf(event_type = 'rst_recv') AS rst_recv,\n  uniq(sec_remote_addr) AS unique_sources\nFROM default.process_metrics\nWHERE event_type IN ('syn_recv', 'rst_sent', 'rst_recv')\n  AND sec_local_port > 0\n  AND timestamp >= $__fromTime AND timestamp <= $__toTime\n  AND hostname IN (${hostname:sqlstring})\nGROUP BY sec_local_port\nORDER BY syn_count DESC\nLIMIT 30",
          "refId": "A"
        }
      ],
