          "rawSql": "SELECT\n  timestamp,\n  event_type,\n  sec_local_addr AS local_addr,\n  sec_local_port AS local_port,\n  sec_remote_addr AS remote_addr,\n  sec_remote_port AS remote_port,\n  comm,\n  pid,\n  CASE sec_af WHEN 2 THEN 'IPv4' WHEN 10 THEN 'IPv6' ELSE toString(sec_af) END AS af,\n  sec_tcp_state AS tcp_state,\n  sec_direction AS direction\nFROM default.process_metrics\nWHERE event_type IN ('tcp_retrans', 'syn_recv', 'rst_sent', 'rst_recv')\n  AND timestamp >= $__fromTime AND timestamp <= $__toTime\n  AND hostname IN (${hostname:sqlstring})\nORDER BY timestamp DESC\nLIMIT 200",
          "refId": "A"
        }
      ],
