          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  toStartOfInterval(timestamp, INTERVAL ${agg_interval} MINUTE) AS time,\n  sec_remote_addr AS source,\n  count() AS events\nFROM default.process_metrics\nWHERE event_type = 'syn_recv'\n  AND sec_remote_addr != ''\n  AND timestamp >= $__fromTime AND timestamp <= $__toTime\n  AND hostname IN (${hostname:sqlstring})\n  AND sec_remote_addr IN (\n    SELECT sec_remote_addr\n    FROM default.process_metrics\n    WHERE event_type = 'syn_recv'\n      AND timestamp >= $__fromTime AND timestamp <= $__toTime\n      AND hostname IN (${hostname:sqlstring})\n    GROUP BY sec_remote_addr\n    ORDER BY count() DESC\n    LIMIT 10\n  )\nGROUP BY time, source\nORDER BY time",
          "refId": "A"
        }
