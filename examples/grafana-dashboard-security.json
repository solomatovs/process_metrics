      "targets": [
        {
          "datasource": {
            "type": "grafana-clickhouse-datasource",
            "uid": "${DS_CLICKHOUSE}"
          },
          "format": 1,
          "queryType": "sql",
          "rawSql": "SELECT\n  toStartOfInterval(timestamp, INTERVAL ${agg_interval} MINUTE) AS time,\n  event_type,\n  CASE\n    WHEN event_type = 'udp_agg' THEN sum(file_read_bytes + file_write_bytes)\n    WHEN event_type = 'icmp_agg' THEN sum(open_tcp_conns)\n    ELSE count()\n  END AS events\nFROM default.process_metrics\nWHERE event_type IN ('tcp_retrans', 'syn_recv', 'rst_sent', 'rst_recv', 'udp_agg', 'icmp_agg')\n  AND timestamp >= $__fromTime AND timestamp <= $__toTime\n  AND hostname IN (${hostname:sqlstring})\nGROUP BY time, event_type\nORDER BY time",
          "refId": "A"
        }
      ],
      "title": "Security Events (stacked)",
      "type": "timeseries"
